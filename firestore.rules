rules_version = '2';

// ============================================================================
// LINKFLOW - REGRAS DO FIRESTORE
// Projeto: linkflow-bf1bb
// ============================================================================
// Coleções:
//   - users/{userId}                    → perfis públicos
//   - users/{userId}/links/{linkId}    → blocos/links da landing page
//   - users/{userId}/clicks/{clickId}  → log de cliques (analytics)
//   - posts/{postId}                    → posts do feed comunitário
//   - posts/{postId}/comments/{cmtId}  → comentários dos posts
//   - follows/{followId}                → relacionamentos de seguir
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'brisasofc@gmail.com';
    }
    function isBanned() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('banned', false) == true;
    }
    function validString(s, minLen, maxLen) {
      return s is string && s.size() >= minLen && s.size() <= maxLen;
    }
    function optionalString(s, maxLen) {
      return !(s is string) || s is string && s.size() <= maxLen;
    }
    function isValidUsername(u) {
      return u is string && u.size() >= 3 && u.size() <= 30 && u.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function isValidColor(c) {
      // aceita hex (#fff, #ffffff), rgb(), rgba(), hsl(), hsla() ou vazio
      return c == '' ||
             c.matches('^#([0-9a-fA-F]{3}|[0-9a-fA-F]{4}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$') ||
             c.matches('^rgba?\\(') ||
             c.matches('^hsla?\\(');
    }
    function isValidGradient(g) {
      return g == '' || g.matches('^linear-gradient\\(') || g.matches('^radial-gradient\\(') || g.matches('^conic-gradient\\(');
    }

    // ==========================================================================
    // USERS /{userId}
    // ==========================================================================
    match /users/{userId} {
      allow read: if true;  // perfis são públicos

      // Criação do próprio perfil (no registro)
      allow create: if isOwner(userId) && !isBanned()
        && validString(request.resource.data.username, 3, 30)
        && isValidUsername(request.resource.data.username)
        && validString(request.resource.data.displayName, 1, 60)
        && optionalString(request.resource.data.bio, 280)
        && optionalString(request.resource.data.profilePicUrl, 2048)
        && optionalString(request.resource.data.coverUrl, 2048)
        && optionalString(request.resource.data.coverColor, 100)
        && optionalString(request.resource.data.coverGradient, 500)
        && request.resource.data.theme is map
        && request.resource.data.uid == userId
        && request.resource.data.email is string;

      // Edição do próprio perfil (não pode mudar uid, email, role, banned, contadores)
      allow update: if isOwner(userId) && !isBanned()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.banned == resource.data.banned
        && request.resource.data.followersCount == resource.data.followersCount
        && request.resource.data.followingCount == resource.data.followingCount
        && validString(request.resource.data.username, 3, 30)
        && isValidUsername(request.resource.data.username)
        && validString(request.resource.data.displayName, 1, 60)
        && optionalString(request.resource.data.bio, 280)
        && optionalString(request.resource.data.profilePicUrl, 2048)
        && optionalString(request.resource.data.coverUrl, 2048)
        && optionalString(request.resource.data.coverColor, 100)
        && optionalString(request.resource.data.coverGradient, 500)
        && request.resource.data.theme is map;

      // Admin pode banar/desbanar/editar qualquer perfil
      allow update: if isAdmin();

      // Admin pode deletar usuários
      allow delete: if isAdmin();

      // ======================================================================
      // LINKS /{linkId}  (blocos da landing page)
      // ======================================================================
      match /links/{linkId} {
        allow read: if true;  // links públicos são visíveis para todos

        allow create: if isOwner(userId) && !isBanned()
          && validString(request.resource.data.title, 1, 120)
          && optionalString(request.resource.data.url, 2048)
          && request.resource.data.userId == userId
          && request.resource.data.id == linkId
          && request.resource.data.active is bool
          && request.resource.data.order is number
          && linkFieldsAreValid();

        allow update: if isOwner(userId) && !isBanned()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.id == resource.data.id
          && validString(request.resource.data.title, 1, 120)
          && optionalString(request.resource.data.url, 2048)
          && request.resource.data.active is bool
          && request.resource.data.order is number
          && linkFieldsAreValid();

        allow delete: if isOwner(userId) && !isBanned();
        allow delete: if isAdmin();

        // Validação centralizada de todos os campos de um link
        function linkFieldsAreValid() {
          let d = request.resource.data;
          return
            // Campos básicos
            optionalString(d.subtitle, 200) &&
            optionalString(d.badgeText, 30) &&
            optionalString(d.iconEmoji, 20) &&
            (d.animation == 'none' || d.animation == 'pulse' || d.animation == 'wobble' ||
             d.animation == 'bounce' || d.animation == 'glow') &&
            (d.type == 'link' || d.type == 'whatsapp' || d.type == 'telegram' ||
             d.type == 'buy_now' || d.type == 'payment' || d.type == 'products' ||
             d.type == 'services' || d.type == 'service_card' || d.type == 'testimonials' ||
             d.type == 'gallery' || d.type == 'promo_banner') &&
            optionalString(d.imageUrl, 2048) &&

            // Personalização avançada (todos opcionais)
            optionalString(d.customColor, 200) &&
            isValidColor(d.customColor) &&
            optionalString(d.customTextColor, 200) &&
            isValidColor(d.customTextColor) &&
            optionalString(d.customGradient, 500) &&
            isValidGradient(d.customGradient) &&
            (d.useGradient is bool) &&
            optionalString(d.customBorderColor, 200) &&
            isValidColor(d.customBorderColor) &&
            (d.customBorderWidth is number) && d.customBorderWidth >= 0 && d.customBorderWidth <= 8 &&
            (d.customStyle == '' || d.customStyle == 'flat' || d.customStyle == 'rounded' ||
             d.customStyle == 'outline' || d.customStyle == 'shadow' || d.customStyle == 'brutalist' ||
             d.customStyle == 'glass' || d.customStyle == 'gradient' || d.customStyle == 'neon') &&
            (d.customRadius == '' || d.customRadius == 'none' || d.customRadius == 'subtle' ||
             d.customRadius == 'medium' || d.customRadius == 'full' || d.customRadius == 'pill') &&
            (d.customSize == '' || d.customSize == 'small' || d.customSize == 'medium' ||
             d.customSize == 'large' || d.customSize == 'xl') &&
            (d.customFont == '' || d.customFont == 'sans' || d.customFont == 'serif' ||
             d.customFont == 'mono' || d.customFont == 'space' || d.customFont == 'outfit' ||
             d.customFont == 'syne' || d.customFont == 'bebas' || d.customFont == 'caveat') &&
            (d.customTextAlign == '' || d.customTextAlign == 'left' || d.customTextAlign == 'center' ||
             d.customTextAlign == 'right') &&
            (d.customLetterSpacing == '' || d.customLetterSpacing == 'tight' ||
             d.customLetterSpacing == 'normal' || d.customLetterSpacing == 'wide' ||
             d.customLetterSpacing == 'wider') &&
            (d.customUppercase is bool) &&
            (d.customIconPosition == '' || d.customIconPosition == 'left' ||
             d.customIconPosition == 'right' || d.customIconPosition == 'top' ||
             d.customIconPosition == 'none') &&
            (d.customShadow is bool) &&
            (d.customGlass is bool);
        }
      }

      // ======================================================================
      // CLICKS /{clickId}  (registro anônimo de cliques em links)
      // ======================================================================
      match /clicks/{clickId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if true;  // qualquer visitante pode registrar um clique
        allow update, delete: if isAdmin();
      }
    }

    // ==========================================================================
    // POSTS /{postId}  (feed comunitário)
    // ==========================================================================
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && !isBanned()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.id == postId
        && validString(request.resource.data.caption, 0, 1000)
        && optionalString(request.resource.data.imageUrl, 2048)
        && request.resource.data.likes is list
        && request.resource.data.likesCount is number
        && request.resource.data.commentsCount is number;
      allow update: if isSignedIn() && !isBanned()
        && (request.resource.data.userId == resource.data.userId || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());

      // COMMENTS
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && !isBanned()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.id == commentId
          && request.resource.data.postId == postId
          && validString(request.resource.data.text, 1, 600)
          && optionalString(request.resource.data.displayName, 60)
          && optionalString(request.resource.data.username, 30)
          && optionalString(request.resource.data.profilePicUrl, 2048);
        allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
        allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      }
    }

    // ==========================================================================
    // FOLLOWS /{followId}
    // ==========================================================================
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && !isBanned()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.id == followId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.followerId;
      allow update: if false;  // imutável
    }
  }
}
